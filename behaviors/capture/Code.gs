/**
 * Estate OS — Capture App (Google Apps Script Backend)
 * =====================================================
 * Saves voice memo transcripts as .md files to Google Drive.
 *
 * SETUP:
 *   1. Create a new Google Apps Script project
 *   2. Paste this into Code.gs
 *   3. Paste Index.html into a new HTML file
 *   4. Deploy as web app (Execute as: Me, Access: Anyone with link)
 *   5. Add the deployed URL to Android home screen
 *
 * URL PARAMETERS:
 *   ?user=MHH  (default) — saves to MHH-Inbox folder
 *   ?user=HBS           — saves to HBS-Inbox folder (Phase 2)
 */

var ICON_B64 = '';

function getOrCreateIconUrl() {
  var props = PropertiesService.getScriptProperties();
  var url = props.getProperty('iconUrl');
  if (url) return url;
  var bytes = Utilities.base64Decode(ICON_B64);
  var blob = Utilities.newBlob(bytes, 'image/png', 'estate-capture-icon.png');
  var file = DriveApp.createFile(blob);
  file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
  url = 'https://drive.google.com/uc?export=view&id=' + file.getId();
  props.setProperty('iconUrl', url);
  return url;
}

function setupIcon() {
  var url = getOrCreateIconUrl();
  Logger.log('Icon URL: ' + url);
  return url;
}

function doGet(e) {
  // Serve Web App Manifest for Android home screen icon
  if (e && e.parameter && e.parameter.manifest === '1') {
    var iconUrl = getOrCreateIconUrl();
    var manifest = {
      name: 'Estate Capture',
      short_name: 'Estate',
      display: 'standalone',
      background_color: '#ffffff',
      theme_color: '#002f6c',
      icons: [
        { src: iconUrl, sizes: '192x192', type: 'image/png', purpose: 'any maskable' }
      ]
    };
    return ContentService
      .createTextOutput(JSON.stringify(manifest))
      .setMimeType(ContentService.MimeType.JSON);
  }

  var html = HtmlService.createHtmlOutputFromFile('Index')
    .setTitle('Estate Capture')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);

  // Pass user parameter to the page
  var user = (e && e.parameter && e.parameter.user) ? e.parameter.user.toUpperCase() : 'MHH';
  html.append('<script>var CAPTURE_USER = "' + user + '";</script>');

  return html;
}

function saveCapture(content, filename, user) {
  try {
    var folderName = (user || 'MHH') + '-Inbox';
    var folders = DriveApp.getFoldersByName(folderName);
    var folder;

    if (folders.hasNext()) {
      folder = folders.next();
    } else {
      folder = DriveApp.createFolder(folderName);
    }

    folder.createFile(filename, content, MimeType.PLAIN_TEXT);
    return 'saved';

  } catch(e) {
    throw new Error('Could not save to Google Drive: ' + e.message);
  }
}

/**
 * POST endpoint for GitHub Pages-hosted capture app.
 * Expects JSON body: { content: "...", filename: "...", user: "MHH" }
 * Returns JSON: { status: "saved" } or { status: "error", message: "..." }
 */
function doPost(e) {
  try {
    var data = JSON.parse(e.postData.contents);
    var content = data.content || '';
    var filename = data.filename || 'capture-unknown.md';
    var user = data.user || 'MHH';

    saveCapture(content, filename, user);

    return ContentService
      .createTextOutput(JSON.stringify({ status: 'saved' }))
      .setMimeType(ContentService.MimeType.JSON);

  } catch(err) {
    return ContentService
      .createTextOutput(JSON.stringify({ status: 'error', message: err.message }))
      .setMimeType(ContentService.MimeType.JSON);
  }
}
